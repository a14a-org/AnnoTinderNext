# Database connection string
# For SQLite (local development):
DATABASE_URL="file:./dev.db"

# For PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@host:5432/database"

# Authentication (Auth.js / NextAuth)
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Resend API key for magic link emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxx"

# Email sender address (must be verified in Resend)
EMAIL_FROM="noreply@yourdomain.com"

# GlitchTip / Sentry error tracking
# Public DSN (safe to expose to the browser); enables error reporting in production
NEXT_PUBLIC_SENTRY_DSN="https://<key>@errors.a14a.org/<project-id>"
# Auth token used only at build time to upload source maps (keep server-side / CI only)
# SENTRY_AUTH_TOKEN="sntrys_xxxxx"
